logs/
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE & OS
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db


################
# Web frontend #
################

web/node_modules/
web/dist/
web/build/
web/.vite/
web/.cache/

